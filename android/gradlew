#!/bin/sh

# Gradle startup script for POSIX generated by Gradle.

# Attempt to set APP_HOME
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`/"$link"
    fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
APP_HOME="`pwd -P`"
cd "$SAVED" >/dev/null

DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

if [ ! -x "$JAVACMD" ] ; then
    echo "Error: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2
    exit 1
fi

if [ ! -f "$CLASSPATH" ] ; then
    # Download wrapper jar if missing
    echo "Downloading Gradle wrapper..."
    GRADLE_VERSION=$(cat "$APP_HOME/gradle/wrapper/gradle-wrapper.properties" | grep distributionUrl | sed 's/.*gradle-\(.*\)-all.zip/\1/')
    download_url="https\://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-wrapper.jar"
    curl -sSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-wrapper.jar" -o "$CLASSPATH"
    
    if [ ! -f "$CLASSPATH" ] ; then
        echo "Error: Could not download gradle wrapper jar." >&2
        exit 1
    fi
fi

exec "$JAVACMD" $DEFAULT_JVM_OPTS $JAVA_OPTS \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain "$@"
